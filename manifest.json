{
  "version": "1.0",
  "manifest_version": 3,
  "name": "Screener",
  "permissions": [
    "debugger",
    "activeTab",
    "tabs",
    "downloads",
    "scripting"
  ],
  "background": {
    "service_worker": "Screener.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}